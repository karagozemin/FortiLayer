{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "declaration": true,
    "resolveJsonModule": true,
    "sourceMap": true
  },
  "include": [
    "./scripts",
    "./test",
    "./hardhat.config.ts",
    "./typechain-types"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "artifacts",
    "cache",
    "frontend"
  ]
}