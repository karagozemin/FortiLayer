# ══════════════════════════════════════════════════════════════
#  FortiLayer — Environment Configuration
# ══════════════════════════════════════════════════════════════

# Private key for deployment (WITHOUT 0x prefix)
PRIVATE_KEY=your_private_key_here

# Arbitrum Sepolia RPC URL
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# Arbiscan API key for contract verification
ARBISCAN_API_KEY=your_arbiscan_api_key_here

# Gas reporter (set to "true" to enable)
REPORT_GAS=false

# Deployed contract addresses (populated after deployment)
POLICY_ENGINE_ADDRESS=
TREASURY_FIREWALL_ADDRESS=
POLICY_REGISTRY_ADDRESS=
TREASURY_ADDRESS=
MOCK_USDC_ADDRESS=
SPENDING_LIMIT_POLICY_ADDRESS=
WHITELIST_POLICY_ADDRESS=
TIMELOCK_POLICY_ADDRESS=
RISK_SCORE_POLICY_ADDRESS=